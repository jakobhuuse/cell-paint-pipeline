# Cluster values for render.sh — copy to cluster.env, fill in, then run ./render.sh
# cluster.env, munge.key and *.local.yaml are git-ignored (never committed).

# Head node short hostname. Set the head instance's name to this in Horizon.
HEAD_HOST=head

# Head node's INTERNAL tenant IP — read it from the Horizon Instances list AFTER the head boots.
HEAD_IP=10.0.0.10

# Tenant subnet CIDR allowed to NFS-mount the head's /data export.
TENANT_CIDR=10.0.0.0/24

# SLURM NodeName spec — must match the compute instance names you launch in Horizon.
#   ten nodes named compute-1 ... compute-10  ->  compute-[1-10]
COMPUTE_NODES=compute-[1-10]

# /etc/hosts lines for the compute nodes ("<internal-ip> <name>", semicolon-separated).
# Fill in the REAL internal IPs after the compute instances boot (Horizon shows them). render.sh
# prints the command to apply these on the head (Step 4) — they are NOT baked into the cloud-init.
COMPUTE_HOSTS="10.0.0.11 compute-1;10.0.0.12 compute-2;10.0.0.13 compute-3;10.0.0.14 compute-4;10.0.0.15 compute-5;10.0.0.16 compute-6;10.0.0.17 compute-7;10.0.0.18 compute-8;10.0.0.19 compute-9;10.0.0.20 compute-10"
