#cloud-config
#
# Head-node launch template.
#
#   cp head.yaml.example head.yaml     # head.yaml is git-ignored
#   $EDITOR head.yaml                  # fill in the block below
#
# Then paste head.yaml into Horizon's
# Compute -> Instances -> Launch Instance -> Configuration -> Customization Script.
#
# DO NOT put your credential in this .example file. It is tracked in git.
#
# The head is the ONLY thing you create by hand. It builds the rest of the cluster
# itself through the OpenStack API.

write_files:
  - path: /etc/cluster/cluster.env
    permissions: '0600'
    owner: root:root
    content: |
      # ===================== EDIT BEFORE LAUNCHING =====================

      # Application credential for this project. Create it in Horizon under
      # Identity -> Application Credentials. It needs a role that can CREATE
      # servers and volumes (`member`), not just `reader`.
      #
      # NOTE: whatever you put here is readable by anyone with a shell on the
      # head, via the metadata service. Scope the credential to this project,
      # give it an expiry, and do not reuse a personal unrestricted one.
      #
      # Use the values from the clouds.yaml file.
      OS_AUTH_URL=https://CHANGEME:5000
      OS_REGION_NAME=RegionOne
      OS_APP_CRED_ID=CHANGEME
      OS_APP_CRED_SECRET=CHANGEME

      # Names compute nodes <CLUSTER_NAME>-compute-N, and tags them so that
      # `cluster down` can only ever delete this cluster's own nodes.
      CLUSTER_NAME=cp

      # Where the head fetches head-setup.sh and the `cluster` tool from.
      # Pin CLUSTER_REF to a tag if needed/wanted.
      CLUSTER_REPO=https://github.com/jakobhuuse/cell-paint-pipeline
      CLUSTER_REF=main

      # =================================================================

  - path: /usr/local/sbin/cluster-bootstrap.sh
    permissions: '0755'
    owner: root:root
    content: |
      #!/bin/bash
      # Fetch the deploy scripts, then hand over to head-setup.sh. Kept minimal
      # on purpose: everything it pulls down is a reviewable file in the repo
      # rather than YAML-embedded here.
      #
      # No `set -x`: cluster.env holds the credential and cloud-init's output log
      # is world-readable.
      set -euo pipefail

      # shellcheck source=/dev/null
      . /etc/cluster/cluster.env

      export DEBIAN_FRONTEND=noninteractive
      APT='apt-get -o DPkg::Lock::Timeout=300 -y'
      $APT update
      $APT install curl ca-certificates tar

      tmp=$(mktemp -d)
      trap 'rm -rf "$tmp"' EXIT
      curl -fsSL "${CLUSTER_REPO}/archive/${CLUSTER_REF}.tar.gz" -o "$tmp/src.tgz"
      tar xzf "$tmp/src.tgz" -C "$tmp"

      install -d -m 0755 /opt/cluster
      cp -r "$tmp"/*/deploy/. /opt/cluster/
      # Symlinked without the extension: it is a source file in the repo, but a
      # command on the head, and `cluster up` reads better than `cluster.py up`.
      chmod +x /opt/cluster/cluster.py /opt/cluster/head-setup.sh
      ln -sf /opt/cluster/cluster.py /usr/local/bin/cluster

      exec bash /opt/cluster/head-setup.sh

runcmd:
  - bash /usr/local/sbin/cluster-bootstrap.sh
