# Cluster values for render.sh — copy to cluster.env, fill in, then run ./render.sh
# cluster.env, munge.key and *.local.yaml are git-ignored (never committed).

# --- Enter before launching the head node (needed to render head.local.yaml) ---

# Head node short hostname. Set the head instance's name to this.
HEAD_HOST=head

# Tenant subnet CIDR allowed to NFS-mount the head's /data export.
TENANT_CIDR=10.0.0.0/24

# SLURM NodeName spec. Must match the compute instance names you launch.
#   ten nodes named compute-1 ... compute-10  ->  compute-[1-10]
COMPUTE_NODES=compute-[1-10]

# Compute-node flavor sizing. Must match what you launch in OpenStack.
CPUS=16
REAL_MEMORY=48000
MEM_SPEC_LIMIT=6144

# --- Enter after the head node boots (needed to render compute.local.yaml) ---

# Head node's INTERNAL tenant IP.
HEAD_IP=10.0.0.10
