manifest {
    name        = 'cell-painting-pipeline'
    description = 'Cell-painting feature-extraction pipeline (CellProfiler/DeepProfiler/CytoTable/pycytominer)'
    mainScript  = 'main.nf'
    nextflowVersion = '>=23.10.0'
}

//Default parameters
params {
    //Paths
    outdir     = 'results'
    input_dir  = 'testdata/'
    plate_glob = '*/*'

    //Cellprofiler
    illum_cppipe       = "conf/cellprofiler/pipelines/illum.cppipe"
    analysis_cppipe    = "conf/cellprofiler/pipelines/analysis.cppipe"
    deepprofiler_cppipe = "conf/cellprofiler/pipelines/deepprofiler.cppipe"
    cellprofiler_image = 'cellprofiler/cellprofiler:4.2.8'

    //cytopipe (CytoTable glue layer) — built from the separate cytopipe repo:
    //  https://github.com/jakobhuuse/cytopipe
    cytopipe_image = 'ghcr.io/jakobhuuse/cytopipe:dev'
}

process {
    cpus   = 2
    memory = 8.GB

    withLabel: cellprofiler {
        container = params.cellprofiler_image
        containerOptions = '--entrypoint ""'
    }
    withName: CYTOTABLE      { container = params.cytopipe_image }
    //withName: PYCYTOMINER  { container = params.pycytominer_image }
    /*withName: DEEPPROFILER {
        container = params.deepprofiler_image
        // GPU stage — wired per-profile (see slurm profile / TODO for local GPU).
        label = 'gpu'
    }
    */
}

profiles {
    //dev
    standard {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    //deploy
    /*
    slurm {
        process.executor = 'slurm'
        apptainer.enabled = true
        apptainer.autoMounts = true
        // .sif cache (see .env APPTAINER_CACHEDIR). TODO: set queue/partition + GPU clause.
        apptainer.cacheDir = System.getenv('APPTAINER_CACHEDIR') ?: "${launchDir}/.apptainer"
        process {
            queue = 'normal'
            // withLabel: gpu { clusterOptions = '--gres=gpu:1'; queue = 'gpu' }
        }
    }
    */
}
