manifest {
    name        = 'cell-painting-pipeline'
    description = 'Cell-painting feature-extraction pipeline (CellProfiler/DeepProfiler/CytoTable/pycytominer)'
    mainScript  = 'main.nf'
    nextflowVersion = '>=26.04.0'
}

//Default parameters
params {
    //Project
    outdir     = 'results'
    input_dir  = 'testdata'
    plate_glob = '*/*'

    //CellProfiler
    cellprofiler_image = 'cellprofiler/cellprofiler:4.2.8'
    illum_cppipe       = "conf/cellprofiler/illum.cppipe"
    analysis_cppipe    = "conf/cellprofiler/analysis.cppipe"
    nuclei_cppipe = "conf/cellprofiler/nuclei.cppipe"
    // Image-sets (sites) per CellProfiler analysis/nuclei chunk (one LoadData CSV slice each).
    cellprofiler_chunk_size = 50
    
    //Cytopipe
    cytopipe_image = 'ghcr.io/jakobhuuse/cytopipe'

    //DeepProfiler
    deepprofiler_image = 'ghcr.io/jakobhuuse/deepprofiler:0.5.1'
    deepprofiler_model = 'conf/deepprofiler/model.hdf5'
    deepprofiler_config = 'conf/deepprofiler/config.json'
    deepprofiler_embedding_dim = 672

    //Pycytominer
    pycytominer_image = 'cytomining/pycytominer:1.5.1_260603'
    pycytominer_aggregate_strata_dp   = 'Metadata_Plate,Metadata_Well,Metadata_Compound'
    pycytominer_aggregate_strata_cp = 'Metadata_Plate,Metadata_Well'
    pycytominer_normalize_samples  = "Metadata_Compound == 'DMSO'"
    pycytominer_feature_select_ops = "variance_threshold,correlation_threshold,blocklist"
    pycytominer_consensus_columns  = 'Metadata_Compound'
}

// Base directory for workflow `publish:`/`output {}` targets.
outputDir = params.outdir

// Publish outputs by copying (default is symlink, which breaks on work/ cleanup).
workflow.output.mode = 'copy'

process {
    // Defaults.
    cpus   = 1
    memory = 3.GB
    containerOptions = '--entrypoint "" --platform linux/amd64'
    cache = 'lenient'

    // --- Containers / execution settings (grouped by tool) ---
    withLabel: cellprofiler     { container = params.cellprofiler_image }
    withLabel: deepprofiler     { container = params.deepprofiler_image }
    withLabel: pycytominer      { container = params.pycytominer_image }
    // cytotable in cytopipe runs as the host uid with no passwd entry. Give it USER/HOME.
    withLabel: cytopipe         { 
                                container = params.cytopipe_image 
                                containerOptions = '--entrypoint "" -e USER=cytopipe -e HOME=/tmp'
                                }

    // --- Resources (per process) ---
    // CellProfiler's `-c -r` CLI is effectively single-threaded.
    withName: DEEPPROFILE               { cpus = 8; memory = 12.GB }
    withName: CELLPROFILER_ANALYSIS     { memory = 8.GB }
}

profiles {
    // dev - CPU
    standard {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    // dev - GPU
    gpu {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            withName: DEEPPROFILE {
                containerOptions = '--entrypoint "" --platform linux/amd64 --gpus all'
                maxForks         = 1
                cpus = 4
            }
        }
    }

    // prod - self-managed SLURM cluster on OpenStack (Apptainer, shared /data over NFS)
    slurm {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        apptainer.cacheDir   = '/data/apptainer-cache'

        // Shared Nextflow work dir on the NFS-mounted volume (identical path on every node).
        workDir = '/data/work'

        executor {
            queueSize       = 100
            submitRateLimit = '20/1min'
        }

        process {
            executor = 'slurm'
            queue    = 'compute'

            // Apptainer ignores image entrypoints and runs native amd64 here, so the base
            // config's Docker-only flags (--entrypoint / --platform / -e) don't apply.
            containerOptions = ''

            // Re-queue OOM/timeout kills (exit 137-140) with more memory; fail fast otherwise.
            errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
            maxRetries    = 2

            // cytotable calls getpass.getuser(), which fails for a uid with no passwd entry;
            // setting USER via --env satisfies it. Apptainer's default HOME (the invoking user's
            // home) is mounted + writable, so DuckDB's ~/.duckdb works without overriding HOME.
            // NB: HOME cannot be set via --env/APPTAINERENV_HOME; if DuckDB ever needs a different
            // writable home, add `--home /tmp` here (not `--env HOME=...`).
            withLabel: cytopipe {
                containerOptions = '--env USER=cytopipe'
            }

            // Escalate memory on retry for the heavy steps (real cgroup caps under SLURM).
            withName: CELLPROFILER_ANALYSIS { memory = { 8.GB * task.attempt } }
            withName: DEEPPROFILE {
                memory = { 12.GB * task.attempt }
                // No GPU: pin TF/OpenMP threads to the SLURM allocation (cgroup affinity is
                // honored, but Python's cpu_count() still sees all host cores).
                containerOptions = { "--env OMP_NUM_THREADS=${task.cpus},TF_NUM_INTRAOP_THREADS=${task.cpus},TF_NUM_INTEROP_THREADS=1" }
            }
        }
    }
}
