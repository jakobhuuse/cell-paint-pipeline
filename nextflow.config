manifest {
    name        = 'cell-painting-pipeline'
    description = 'Cell-painting feature-extraction pipeline (CellProfiler/DeepProfiler/CytoTable/pycytominer)'
    mainScript  = 'main.nf'
    nextflowVersion = '>=23.10.0'
}

//Default parameters
params {
    //Project
    outdir     = '/mnt/d/SINTEF/2025-W51-12-20-deepprofiler'
    input_dir  = '/mnt/d/SINTEF/2025-W51'
    plate_glob = '2025-12-20/*'

    //CellProfiler
    cellprofiler_image = 'cellprofiler/cellprofiler:4.2.8'
    illum_cppipe       = "conf/cellprofiler/pipelines/illum.cppipe"
    analysis_cppipe    = "conf/cellprofiler/pipelines/analysis.cppipe"
    deepprofiler_cppipe = "conf/cellprofiler/pipelines/deepprofiler.cppipe"
    // Image sets (sites) per parallel CellProfiler analysis chunk. Lower = more
    // parallelism but more per-job startup overhead. Illum stays serial (it
    // averages across all cycles, so it can't be chunked).
    cellprofiler_chunk_size = 50
    

    //Cytopipe
    cytopipe_image = 'ghcr.io/jakobhuuse/cytopipe'

    //DeepProfiler
    deepprofiler_image = 'ghcr.io/jakobhuuse/deepprofiler'
    deepprofiler_model = 'conf/deepprofiler/model/Cell_Painting_CNN_v1.hdf5'
    deepprofiler_config = 'conf/deepprofiler/config/profiling.json'
    deepprofiler_embedding_dim = 672

    //Pycytominer
    pycytominer_image = 'cytomining/pycytominer:1.5.1_260603'
    pycytominer_aggregate_strata   = 'Metadata_Plate,Metadata_Well,Metadata_Compound'
    pycytominer_normalize_samples  = "Metadata_Compound == 'DMSO'"
    pycytominer_feature_select_ops = 'variance_threshold'
    pycytominer_consensus_columns  = 'Metadata_Compound'
}

// Base directory for workflow `publish:`/`output {}` targets.
outputDir = params.outdir

process {
    cpus   = 2
    memory = 6.GB
    containerOptions = '--entrypoint "" --platform linux/amd64'

    withLabel: cellprofiler {
        container = params.cellprofiler_image
        // CellProfiler's `-c -r` CLI is effectively single-threaded.
        cpus = 1
        memory = 2.GB
    }

    withLabel: cytopipe {
        container = params.cytopipe_image
    }

    // cytotable runs as the host uid with no passwd entry. Give it USER/HOME.
    withLabel: cytotable {
        containerOptions = '--entrypoint "" -e USER=cytopipe -e HOME=/tmp'
    }

    withLabel: deepprofiler {
        container = params.deepprofiler_image
    }
    withLabel: pycytominer  { 
        container = params.pycytominer_image
    }
}

profiles {
    // dev - CPU
    standard {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    // dev - GPU
    gpu {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            withLabel: deepprofiler {
                containerOptions = '--entrypoint "" --platform linux/amd64 --gpus all'
            }
        }
    }

    // deploy
    hpc {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        process {
            executor         = 'slurm'
            containerOptions = ''
            // Docker-only flags from the base label; Apptainer rejects them, so clear.
            withLabel: cytotable {
                containerOptions = ''
            }
            withLabel: deepprofiler {
                accelerator      = 1
                containerOptions = '--nv'
            }
        }
    }
}
