manifest {
    name        = 'cell-paint-pipeline'
    author      = 'Jakob Huuse'
    homePage    = 'https://github.com/jakobhuuse/cell-paint-pipeline'
    description = 'Cell-paint feature-extraction pipeline (CellProfiler/DeepProfiler/cytopipe/pycytominer)'
    mainScript  = 'main.nf'
    defaultBranch = 'main'
    version     = '1.0.2' //Make sure this matches the GitHub tag
    license     = 'BSD-3-Clause'
    nextflowVersion = '>=26.04.0'
}

//Default parameters
params {
    //Project
    outdir     = 'results'
    input_dir  = "${projectDir}/tests/data"
    plate_glob = '*/*'
    pipeline   = 'deepprofiler'

    //CellProfiler
    cellprofiler_image = 'cellprofiler/cellprofiler:4.2.8'
    qc_cppipe          = "${projectDir}/conf/cellprofiler/1_QC.cppipe"
    illum_cppipe       = "${projectDir}/conf/cellprofiler/2_IllumCorrection.cppipe"
    analysis_cppipe    = "${projectDir}/conf/cellprofiler/3_JUMP_analysis.cppipe"
    nuclei_cppipe      = "${projectDir}/conf/cellprofiler/nuclei.cppipe"
    cellprofiler_chunk_size = 50

    //Cytopipe
    cytopipe_image = 'ghcr.io/jakobhuuse/cytopipe:1.0.2'

    //DeepProfiler
    deepprofiler_image = 'ghcr.io/jakobhuuse/deepprofiler:0.5.1'
    deepprofiler_model = "${projectDir}/conf/deepprofiler/model.hdf5"
    deepprofiler_config = "${projectDir}/conf/deepprofiler/config.json"
    deepprofiler_embedding_dim = 672

    //Pycytominer
    pycytominer_image = 'cytomining/pycytominer:1.5.1_260603'
    pycytominer_aggregate_strata_dp   = 'Metadata_Plate,Metadata_Well,Metadata_Compound'
    pycytominer_aggregate_strata_cp = 'Metadata_Plate,Metadata_Well'
    pycytominer_annotate_join_on   = 'Metadata_DestinationWell,Metadata_Well'
    pycytominer_normalize_samples  = "Metadata_Compound == 'DMSO'"
    pycytominer_feature_select_ops = "variance_threshold,correlation_threshold,blocklist"
    pycytominer_consensus_columns  = 'Metadata_Compound'
}

// Base directory for workflow `publish:`/`output {}` targets.
outputDir = params.outdir

params.runStamp = new Date().format('yyyy-MM-dd_HH-mm-ss')

trace {
    enabled = true
    file    = "${params.outdir}/nextflow/${params.runStamp}/trace.txt"
}
report {
    enabled = true
    file    = "${params.outdir}/nextflow/${params.runStamp}/report.html"
}
timeline {
    enabled = true
    file    = "${params.outdir}/nextflow/${params.runStamp}/timeline.html"
}

process {
    // Defaults.
    cpus   = { 1 * task.attempt }
    memory = { 4.GB * task.attempt }
    containerOptions = '--entrypoint "" --platform linux/amd64'
    cache = 'lenient'
    errorStrategy = { task.exitStatus in [130, 137, 140, 143] ? 'retry' : 'finish' }
    maxRetries = 2

    // --- Containers / execution settings (grouped by tool) ---
    withLabel: cellprofiler     { container = params.cellprofiler_image }
    withLabel: deepprofiler     { container = params.deepprofiler_image }
    withLabel: pycytominer      { container = params.pycytominer_image }
    // cytotable in cytopipe runs as the host uid with no passwd entry. Give it USER/HOME.
    withLabel: cytopipe         {
                                container = params.cytopipe_image
                                containerOptions = '--entrypoint "" --platform linux/amd64 -e USER=cytopipe -e HOME=/tmp'
                                }

    // Plates missing from the platemap (or otherwise lacking DMSO controls) have no rows
    // matching pycytominer_normalize_samples, so pycytominer normalize errors.
    withName: PYCYTOMINER_NORMALIZE {errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'ignore' }}

    // --- Resources ---
    // Deepprofiler
    withName: DEEPPROFILE           { cpus = 4 }
    withName: DEEPPROFILER_PREPARE  { cpus = 2; memory = { 6.GB * task.attempt } }
    withName: CYTOPIPE_DEEPPROFILER_PARQUET { cpus = 2; memory = {16.GB * task.attempt } }
    withName: CELLPROFILER_NUCLEI { memory = { 1.GB +  60.MB * (params.cellprofiler_chunk_size as int) * task.attempt } }

    // Cellprofiler
    withName: CYTOPIPE_CELLPROFILER_PARQUET { cpus = 2; memory = {16.GB * task.attempt } }
    withName: CELLPROFILER_ANALYSIS { memory = { 1.GB +  120.MB * (params.cellprofiler_chunk_size as int) * task.attempt } }
    withName: CELLPROFILER_QC { memory = { 1.GB +  60.MB * (params.cellprofiler_chunk_size as int) * task.attempt } }

    // Pycytominer
    withLabel: pycytominer { cpus = 4; memory = {16.GB * task.attempt } }

    // Whole-cohort steps
    withLabel: cohort               { memory = { 16.GB * task.attempt } }
}

profiles {
    // dev - CPU
    standard {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    // dev - GPU
    gpu {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            withName: DEEPPROFILE {
                containerOptions = '--entrypoint "" --platform linux/amd64 --gpus all'
                maxForks         = 1
            }
        }
    }

    // prod - self-managed SLURM cluster on OpenStack (Apptainer, shared /data over NFS)
    slurm {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        apptainer.cacheDir   = '/data/apptainer-cache'

        // Shared Nextflow work dir on the NFS-mounted volume (identical path on every node).
        workDir = '/data/work'

        executor {
            queueSize       = 100
            submitRateLimit = '20/1min'
        }

        process {
            executor = 'slurm'
            queue    = 'compute'

            // Apptainer ignores image entrypoints and runs native amd64 here, so the base
            // config's Docker-only flags (--entrypoint / --platform / -e) don't apply.
            containerOptions = ''

            // Cluster-wide TMPDIR points at /data/tmp (NFS) so Apptainer has room to build/extract
            // images. Containers inherit it via APPTAINERENV_TMPDIR, which also redirects libraries'
            // scratch I/O (e.g. CellProfiler/h5py measurement files) there. Concurrent HDF5 I/O over
            // NFS triggers spurious EIO crashes, so force task scratch onto node-local disk instead.
            beforeScript = 'export TMPDIR=/tmp'

            // cytotable calls getpass.getuser() (needs USER set) and DuckDB reads $HOME. The
            // invoking user's host home is NOT mounted inside the container on compute nodes, so
            // give HOME a writable, existing path via --home /tmp.
            withLabel: cytopipe {
                containerOptions = '--home /tmp --env USER=cytopipe'
            }

            withName: DEEPPROFILE {
                memory = { 12.GB * task.attempt }
                // No GPU: pin TF/OpenMP threads to the SLURM allocation (cgroup affinity is
                // honored, but Python's cpu_count() still sees all host cores).
                containerOptions = { "--env OMP_NUM_THREADS=${task.cpus},TF_NUM_INTRAOP_THREADS=${task.cpus},TF_NUM_INTEROP_THREADS=1" }
            }
        }
    }
}
