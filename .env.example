# Copy to .env and adjust. These are consumed by Nextflow / deploy scripts,
# not loaded into the Python process.

# --- Container image tags (override to use a private registry / pinned digests) ---
CELLPROFILER_IMAGE=cellprofiler/cellprofiler:4.2.8
DEEPPROFILER_IMAGE=ghcr.io/your-org/deepprofiler:dev
PYCYTOMINER_IMAGE=cytomining/pycytominer:latest
CYTOPIPE_IMAGE=ghcr.io/your-org/cytopipe:dev

# --- Apptainer image dir (HPC). .sif files are built/cached here ---
APPTAINER_CACHEDIR=/scratch/$USER/apptainer

# --- Default pipeline params file ---
PARAMS_FILE=conf/params.yaml
