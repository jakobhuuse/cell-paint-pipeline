manifest {
    name        = 'cytopipe'
    description = 'Cell-painting feature-extraction pipeline (CellProfiler/DeepProfiler/CytoTable/pycytominer)'
    mainScript  = 'main.nf'
    nextflowVersion = '>=23.10.0'
}

params {
    outdir = 'results'

    cellprofiler_image = 'cellprofiler/cellprofiler:4.2.8'
    deepprofiler_image = 'ghcr.io/your-org/deepprofiler:dev'
    pycytominer_image  = 'cytomining/pycytominer:latest'
    cytopipe_image     = 'ghcr.io/your-org/cytopipe:dev'
}

process {
    cpus   = 2
    memory = 8.GB

    withName: CELLPROFILER { container = params.cellprofiler_image }
    withName: CYTOTABLE    { container = params.cytopipe_image }
    withName: PYCYTOMINER  { container = params.pycytominer_image }
    withName: DEEPPROFILER {
        container = params.deepprofiler_image
        // GPU stage — wired per-profile (see slurm profile / TODO for local GPU).
        label = 'gpu'
    }
}

profiles {
    //dev
    standard {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    //deploy
    slurm {
        process.executor = 'slurm'
        apptainer.enabled = true
        apptainer.autoMounts = true
        // .sif cache (see .env APPTAINER_CACHEDIR). TODO: set queue/partition + GPU clause.
        apptainer.cacheDir = System.getenv('APPTAINER_CACHEDIR') ?: "${launchDir}/.apptainer"
        process {
            queue = 'normal'
            // withLabel: gpu { clusterOptions = '--gres=gpu:1'; queue = 'gpu' }
        }
    }
}
