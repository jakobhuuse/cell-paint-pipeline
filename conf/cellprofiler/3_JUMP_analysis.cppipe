ExportToSpreadsheet:[module_num:42|svn_version:'Unknown'|variable_revision_number:13|show_window:False|notes:['We explicitly set which measurement types to export so that we do NOT export measurements of the objects touching the well edges as we ONLY want them for masking and not to use for measurements.', '', 'We have turned off the exporting of measurements starting with the word Location for Cells and Cytoplasm and the duplicate Number_Object_Number from Cells, because a) those measurements are not useful on their own (only relative to one another, which is not an analysis we currently ever perform) and b) we were previously exporting >2000 measurements for those compartments, which would complicate using SQLite if not manually compiled to allow >2000 columns.']|batch_state:array([], dtype=uint8)|enabled:False|wants_pause:False]
